# ============================================
# Career OS
# Git Ignore
# Version 1.0
# ============================================

# -----------------------------
# Operating System Files
# -----------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------
# Visual Studio Code
# -----------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# -----------------------------
# JetBrains IDEs
# -----------------------------
.idea/

# -----------------------------
# Node.js
# -----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------
# Build Output
# -----------------------------
dist/
build/
coverage/

# -----------------------------
# Environment Variables
# -----------------------------
.env
.env.*
!.env.example

# -----------------------------
# Logs
# -----------------------------
logs/
*.log

# -----------------------------
# Cache
# -----------------------------
.cache/
.temp/
tmp/

# -----------------------------
# Test Reports
# -----------------------------
playwright-report/
test-results/

# -----------------------------
# Runtime Data
# -----------------------------
*.pid
*.seed

# -----------------------------
# Package Managers
# -----------------------------
.pnpm-store/

# -----------------------------
# Local Databases
# -----------------------------
*.sqlite
*.sqlite3

# -----------------------------
# Generated Files
# -----------------------------
*.zip
*.tar
*.gz

# -----------------------------
# AI Temporary Files
# -----------------------------
.ai/
.prompts/
.temp-ai/

# -----------------------------
# Replit
# -----------------------------
.replit
.config/

# -----------------------------
# Miscellaneous
# -----------------------------
*.bak
*.tmp
*.swp

# -----------------------------
# Keep Empty Directories
# -----------------------------
!.gitkeep